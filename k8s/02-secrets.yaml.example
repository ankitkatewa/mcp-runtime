# This file contains example secrets for development/testing
# DO NOT commit actual secrets to version control
# Copy this file to create your own 02-secrets.yaml with real values
# and add the real file to .gitignore
apiVersion: v1
kind: Secret
metadata:
  name: mcp-sentinel-secrets
  namespace: mcp-sentinel
type: Opaque
stringData:
  # API keys for authentication (comma-separated list)
  API_KEYS: "your-api-key-here,another-key-here"
  # API key for UI access
  UI_API_KEY: "your-ui-key-here"
  # Optional seeded platform admin account.
  # Use with k8s/21-platform-admin-bootstrap-job.yaml, then remove PLATFORM_ADMIN_PASSWORD.
  PLATFORM_ADMIN_EMAIL: "admin@example.com"
  PLATFORM_ADMIN_PASSWORD: "change-me-now"
  ADMIN_USERS: "admin@example.com"
  # Platform identity database and token signing.
  POSTGRES_USER: "mcp_runtime"
  POSTGRES_PASSWORD: "change-me-postgres"
  POSTGRES_DB: "mcp_runtime"
  POSTGRES_DSN: "postgres://mcp_runtime:change-me-postgres@mcp-sentinel-postgres.mcp-sentinel.svc.cluster.local:5432/mcp_runtime?sslmode=disable"
  PLATFORM_JWT_SECRET: "replace-with-at-least-32-random-bytes"
  # Grafana admin credentials
  GRAFANA_ADMIN_USER: "admin"
  GRAFANA_ADMIN_PASSWORD: "changeme"
